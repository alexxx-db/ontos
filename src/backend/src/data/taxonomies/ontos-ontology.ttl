@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

@prefix ontos: <http://ontos.app/ontology#> .
@prefix odcs: <http://odcs.bitol.io/ontology#> .

# ============================================================================
# ONTOS APPLICATION ONTOLOGY v2.0.0
#
# Prescriptive vocabulary for the Ontos data governance application.
# This ontology drives:
#   - Entity type definitions (dedicated DB models vs asset-backed)
#   - Valid relationships between entity types
#   - Field schemas for UI form rendering
#   - UI metadata (icons, categories, persona visibility)
#
# Two-tier model:
#   Tier 1 "dedicated"  -- own SQL tables, full FK relationships
#   Tier 2 "asset"      -- stored in AssetDb + AssetTypeDb, properties as JSON
# ============================================================================

ontos: a owl:Ontology ;
    rdfs:label "Ontos Application Ontology"@en ;
    rdfs:comment "Prescriptive vocabulary for Ontos data governance entities, relationships, and UI rendering"@en ;
    owl:versionInfo "2.0.0" ;
    owl:imports odcs: ;
    dc:created "2024-09-22" ;
    dc:modified "2026-02-18" ;
    dc:creator "Ontos Data Governance Platform" .


# ############################################################################
#
#   SECTION 1 — UI & SCHEMA META-PROPERTIES
#
#   Annotation properties used on classes and data properties throughout
#   the ontology. The OntologySchemaService reads these to drive the UI.
#
# ############################################################################

# --- Class-level UI annotations ---

ontos:modelTier a owl:AnnotationProperty ;
    rdfs:label "model tier"@en ;
    rdfs:comment "Implementation tier: 'dedicated' (own SQL tables) or 'asset' (AssetDb + AssetTypeDb)"@en ;
    rdfs:range xsd:string .

ontos:uiIcon a owl:AnnotationProperty ;
    rdfs:label "UI icon"@en ;
    rdfs:comment "Lucide icon name for display in the application UI"@en ;
    rdfs:range xsd:string .

ontos:uiCategory a owl:AnnotationProperty ;
    rdfs:label "UI category"@en ;
    rdfs:comment "Grouping category: data, governance, analytics, integration, system"@en ;
    rdfs:range xsd:string .

ontos:uiDisplayOrder a owl:AnnotationProperty ;
    rdfs:label "UI display order"@en ;
    rdfs:comment "Sort order within its category (lower = first)"@en ;
    rdfs:range xsd:integer .

ontos:uiPersonaVisibility a owl:AnnotationProperty ;
    rdfs:label "UI persona visibility"@en ;
    rdfs:comment "Comma-separated persona IDs that can see this type (e.g. 'producer,steward,consumer,admin')"@en ;
    rdfs:range xsd:string .

ontos:uiDetailSections a owl:AnnotationProperty ;
    rdfs:label "UI detail sections"@en ;
    rdfs:comment "JSON array of section configs for the entity detail page"@en ;
    rdfs:range xsd:string .

# --- Field-level UI annotations (on data properties) ---

ontos:uiFieldType a owl:AnnotationProperty ;
    rdfs:label "UI field type"@en ;
    rdfs:comment "Form field widget: text, textarea, select, multiselect, date, boolean, json, number, url"@en ;
    rdfs:range xsd:string .

ontos:uiFieldOrder a owl:AnnotationProperty ;
    rdfs:label "UI field order"@en ;
    rdfs:comment "Display order within a form group (lower = first)"@en ;
    rdfs:range xsd:integer .

ontos:isRequired a owl:AnnotationProperty ;
    rdfs:label "is required"@en ;
    rdfs:comment "Whether this field is required for create/update"@en ;
    rdfs:range xsd:boolean .

ontos:uiFieldGroup a owl:AnnotationProperty ;
    rdfs:label "UI field group"@en ;
    rdfs:comment "Logical form section: basic, governance, technical, metadata"@en ;
    rdfs:range xsd:string .

ontos:uiSelectOptions a owl:AnnotationProperty ;
    rdfs:label "UI select options"@en ;
    rdfs:comment "Comma-separated allowed values for select/multiselect fields"@en ;
    rdfs:range xsd:string .

# --- Relationship-level UI annotations (on object properties) ---

ontos:uiLabel a owl:AnnotationProperty ;
    rdfs:label "UI label"@en ;
    rdfs:comment "Human-readable label for a relationship in the UI"@en ;
    rdfs:range xsd:string .

ontos:cardinality a owl:AnnotationProperty ;
    rdfs:label "cardinality"@en ;
    rdfs:comment "Relationship cardinality: '0..1', '1..1', '0..*', '1..*'"@en ;
    rdfs:range xsd:string .

ontos:uiDisplayContext a owl:AnnotationProperty ;
    rdfs:label "UI display context"@en ;
    rdfs:comment "Where to render: detail-page, sidebar, tab, inline"@en ;
    rdfs:range xsd:string .

ontos:inverseLabel a owl:AnnotationProperty ;
    rdfs:label "inverse label"@en ;
    rdfs:comment "Label shown on the target side of a relationship (e.g. 'Datasets' on a DataProduct, 'Data Product' on a Dataset)"@en ;
    rdfs:range xsd:string .

ontos:isHierarchical a owl:AnnotationProperty ;
    rdfs:label "is hierarchical"@en ;
    rdfs:comment "Marks a relationship as hierarchical/containment (parent-child) for hierarchy browser navigation"@en ;
    rdfs:range xsd:boolean .


# ############################################################################
#
#   SECTION 2 — ROOT & ABSTRACT CLASSES
#
# ############################################################################

ontos:Entity a rdfs:Class ;
    rdfs:label "Entity"@en ;
    rdfs:comment "Root class for all Ontos application entities"@en .

ontos:OrganizationalUnit a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Organizational Unit"@en ;
    rdfs:comment "Base class for organizational structures that contain and organize data assets"@en .

ontos:GovernanceArtifact a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Governance Artifact"@en ;
    rdfs:comment "Base class for governance, compliance, and documentation artifacts"@en .

ontos:Asset a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Asset"@en ;
    rdfs:comment "Base class for all asset-backed entities stored in AssetDb + AssetTypeDb"@en ;
    ontos:modelTier "asset" .


# ############################################################################
#
#   SECTION 3 — TIER 1: DEDICATED MODEL CLASSES
#
#   These have their own SQL tables with full FK relationships.
#
# ############################################################################

# --- Core business entities ---

ontos:DataDomain a rdfs:Class ;
    rdfs:subClassOf ontos:OrganizationalUnit ;
    rdfs:label "Data Domain"@en ;
    rdfs:comment "Logical organizational unit for grouping related data products and assets"@en ;
    skos:example "Customer Domain, Financial Domain, Product Domain" ;
    ontos:modelTier "dedicated" ;
    ontos:uiIcon "Boxes" ;
    ontos:uiCategory "governance" ;
    ontos:uiDisplayOrder 1 ;
    ontos:uiPersonaVisibility "admin,steward,producer,consumer" .

ontos:DataProduct a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Data Product"@en ;
    rdfs:comment "Curated, versioned data offering with defined inputs, outputs, and contracts. Follows ODPS v1.0.0."@en ;
    skos:example "Customer 360 View, Real-time Fraud Detection" ;
    skos:definition "Products belong to domains, contain datasets, and are governed by data contracts" ;
    ontos:modelTier "dedicated" ;
    ontos:uiIcon "Package" ;
    ontos:uiCategory "data" ;
    ontos:uiDisplayOrder 1 ;
    ontos:uiPersonaVisibility "admin,steward,producer,consumer" .

ontos:OutputPort a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Output Port"@en ;
    rdfs:comment "An output endpoint of a data product that exposes data via a specific delivery method"@en ;
    skos:example "Daily Churn Rate, ML Model Endpoint, Weekly Revenue Report" ;
    ontos:modelTier "dedicated" ;
    ontos:uiIcon "ArrowUpFromLine" ;
    ontos:uiCategory "data" ;
    ontos:uiDisplayOrder 1 ;
    ontos:uiPersonaVisibility "admin,steward,producer,consumer" .

ontos:DataContract a rdfs:Class ;
    rdfs:subClassOf ontos:GovernanceArtifact ;
    rdfs:label "Data Contract"@en ;
    rdfs:comment "Formal agreement specifying schema, quality, SLA, and access rules for data. Follows ODCS v3.1.0."@en ;
    skos:example "Customer Data Contract v1.0, Transaction Event Contract v2.1" ;
    ontos:modelTier "dedicated" ;
    ontos:uiIcon "FileCheck" ;
    ontos:uiCategory "governance" ;
    ontos:uiDisplayOrder 2 ;
    ontos:uiPersonaVisibility "admin,steward,producer,consumer" .

ontos:Team a rdfs:Class ;
    rdfs:subClassOf ontos:OrganizationalUnit ;
    rdfs:label "Team"@en ;
    rdfs:comment "Collection of users and groups with specific roles and domain assignments"@en ;
    skos:example "Data Engineering Team, Analytics Team" ;
    ontos:modelTier "dedicated" ;
    ontos:uiIcon "Users" ;
    ontos:uiCategory "governance" ;
    ontos:uiDisplayOrder 3 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .

ontos:Project a rdfs:Class ;
    rdfs:subClassOf ontos:OrganizationalUnit ;
    rdfs:label "Project"@en ;
    rdfs:comment "Workspace container that assigns teams to specific initiatives with isolation boundaries"@en ;
    skos:example "Customer Analytics Platform, Risk Reporting System" ;
    ontos:modelTier "dedicated" ;
    ontos:uiIcon "FolderKanban" ;
    ontos:uiCategory "governance" ;
    ontos:uiDisplayOrder 4 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .

# --- Technical / system dedicated entities ---

ontos:CompliancePolicy a rdfs:Class ;
    rdfs:subClassOf ontos:GovernanceArtifact ;
    rdfs:label "Compliance Policy"@en ;
    rdfs:comment "DSL-based compliance rule with automated evaluation, scoring, and per-entity results"@en ;
    ontos:modelTier "dedicated" ;
    ontos:uiIcon "Scale" ;
    ontos:uiCategory "governance" ;
    ontos:uiDisplayOrder 5 ;
    ontos:uiPersonaVisibility "admin,steward" .

ontos:GenieSpace a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Genie Space"@en ;
    rdfs:comment "Databricks AI-powered natural language query space created from data products"@en ;
    ontos:modelTier "dedicated" ;
    ontos:uiIcon "Sparkles" ;
    ontos:uiCategory "analytics" ;
    ontos:uiDisplayOrder 10 ;
    ontos:uiPersonaVisibility "admin,producer,consumer" .

ontos:SemanticModelEntity a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Semantic Model"@en ;
    rdfs:comment "Uploaded ontology or taxonomy file (TTL, RDF, OWL) stored in the knowledge graph"@en ;
    ontos:modelTier "dedicated" ;
    ontos:uiIcon "Network" ;
    ontos:uiCategory "governance" ;
    ontos:uiDisplayOrder 6 ;
    ontos:uiPersonaVisibility "admin,steward" .

ontos:BusinessRole a rdfs:Class ;
    rdfs:subClassOf ontos:GovernanceArtifact ;
    rdfs:label "Business Role"@en ;
    rdfs:comment "Named role users can hold for ownership assignments (Data Owner, Domain Steward, etc.)"@en ;
    ontos:modelTier "dedicated" ;
    ontos:uiIcon "BadgeCheck" ;
    ontos:uiCategory "governance" ;
    ontos:uiDisplayOrder 7 ;
    ontos:uiPersonaVisibility "admin,steward" .

ontos:ProcessWorkflow a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Process Workflow"@en ;
    rdfs:comment "User-designed automation with validation, approval, notification, and scripting steps"@en ;
    ontos:modelTier "dedicated" ;
    ontos:uiIcon "Workflow" ;
    ontos:uiCategory "system" ;
    ontos:uiDisplayOrder 1 ;
    ontos:uiPersonaVisibility "admin,steward" .

ontos:MdmConfig a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "MDM Configuration"@en ;
    rdfs:comment "Master Data Management configuration with matching rules, source links, and match runs"@en ;
    ontos:modelTier "dedicated" ;
    ontos:uiIcon "GitMerge" ;
    ontos:uiCategory "data" ;
    ontos:uiDisplayOrder 10 ;
    ontos:uiPersonaVisibility "admin,steward" .

# --- Supporting dedicated classes (no direct UI, used in relationships) ---

ontos:TeamMember a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Team Member"@en ;
    rdfs:comment "Individual user or group membership within a team with optional role overrides"@en ;
    ontos:modelTier "dedicated" .

ontos:Ownership a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Ownership"@en ;
    rdfs:comment "Named ownership assignment linking user, role, and entity"@en ;
    skos:definition "Uses named reification pattern to avoid blank nodes while supporting multiple owners with roles" ;
    ontos:modelTier "dedicated" .


# ############################################################################
#
#   SECTION 4 — TIER 2: ASSET-BACKED CLASSES
#
#   Stored in AssetDb + AssetTypeDb. Properties stored as JSON.
#   The OntologySchemaService seeds AssetTypeDb from these definitions.
#
# ############################################################################

# --- Data assets ---

ontos:Dataset a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Dataset"@en ;
    rdfs:comment "Business-level grouping of related tables and views representing a coherent data entity"@en ;
    skos:example "Customer Master Dataset, Transaction Events Dataset" ;
    skos:definition "Sits between Data Product and physical tables: Product > Dataset > Table > Column" ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Database" ;
    ontos:uiCategory "data" ;
    ontos:uiDisplayOrder 2 ;
    ontos:uiPersonaVisibility "admin,steward,producer,consumer" .

ontos:Schema a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Schema"@en ;
    rdfs:comment "Platform-level container (UC schema, BQ dataset, Snowflake schema) that organizes tables and views"@en ;
    skos:example "catalog.sales, project.analytics_dataset" ;
    skos:definition "Structural container between System and Table/View in the platform hierarchy" ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "FolderOpen" ;
    ontos:uiCategory "data" ;
    ontos:uiDisplayOrder 2 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .

ontos:Table a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Table"@en ;
    rdfs:comment "Physical table in a data platform (Unity Catalog, Snowflake, BigQuery, etc.)"@en ;
    skos:example "catalog.schema.customers, catalog.schema.transactions" ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Table2" ;
    ontos:uiCategory "data" ;
    ontos:uiDisplayOrder 3 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .

ontos:View a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "View"@en ;
    rdfs:comment "Physical view in a data platform"@en ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Eye" ;
    ontos:uiCategory "data" ;
    ontos:uiDisplayOrder 4 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .

ontos:Column a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Column"@en ;
    rdfs:comment "Column within a physical table or view"@en ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Columns2" ;
    ontos:uiCategory "data" ;
    ontos:uiDisplayOrder 5 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .

# --- Governance assets ---

ontos:Policy a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Policy"@en ;
    rdfs:comment "Formal, reusable rule for data access, quality, retention, or usage"@en ;
    skos:example "PII Masking Policy, 90-Day Retention Policy" ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Shield" ;
    ontos:uiCategory "governance" ;
    ontos:uiDisplayOrder 10 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .

ontos:BusinessTerm a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Business Term"@en ;
    rdfs:comment "Business glossary term promoted to a first-class cataloged asset with definitions and linked entities"@en ;
    skos:example "Customer, Revenue, Churn Rate" ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "BookOpen" ;
    ontos:uiCategory "governance" ;
    ontos:uiDisplayOrder 11 ;
    ontos:uiPersonaVisibility "admin,steward,producer,consumer" .

# --- Analytics assets ---

ontos:Dashboard a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Dashboard"@en ;
    rdfs:comment "BI dashboard or report consuming data products or physical assets"@en ;
    skos:example "Retail Performance Dashboard, Customer Lifetime Value Report" ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "LayoutDashboard" ;
    ontos:uiCategory "analytics" ;
    ontos:uiDisplayOrder 1 ;
    ontos:uiPersonaVisibility "admin,steward,producer,consumer" .

ontos:Notebook a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Notebook"@en ;
    rdfs:comment "Analytics or data engineering notebook"@en ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "FileCode" ;
    ontos:uiCategory "analytics" ;
    ontos:uiDisplayOrder 2 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .

ontos:MLModel a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "ML Model"@en ;
    rdfs:comment "Machine learning model registered in a model registry"@en ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Brain" ;
    ontos:uiCategory "analytics" ;
    ontos:uiDisplayOrder 3 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .

# --- Integration assets ---

ontos:APIEndpoint a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "API Endpoint"@en ;
    rdfs:comment "Data API endpoint exposing data products or services"@en ;
    skos:example "POST /v1/customers/search, GET /v1/transactions" ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Globe" ;
    ontos:uiCategory "integration" ;
    ontos:uiDisplayOrder 1 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .

ontos:Stream a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Stream"@en ;
    rdfs:comment "Streaming source or sink (Kafka topic, Kinesis stream, Event Hub, etc.)"@en ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Activity" ;
    ontos:uiCategory "integration" ;
    ontos:uiDisplayOrder 2 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .

# --- Semantic / logical model assets ---

ontos:LogicalEntity a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Logical Entity"@en ;
    rdfs:comment "Business-level entity in the conceptual/logical data model (e.g. Customer, Order, Product)"@en ;
    skos:example "Customer, Order, Product, Employee" ;
    skos:definition "Part of the CDM layer connecting business terms to physical implementations" ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Shapes" ;
    ontos:uiCategory "governance" ;
    ontos:uiDisplayOrder 12 ;
    ontos:uiPersonaVisibility "admin,steward,producer,consumer" .

ontos:LogicalAttribute a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Logical Attribute"@en ;
    rdfs:comment "Named attribute of a logical entity representing a business-meaningful data element"@en ;
    skos:example "Customer.Id, Customer.Email, Order.TotalAmount" ;
    skos:definition "Bridges business terms to physical columns via implemented_by relationships" ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Tag" ;
    ontos:uiCategory "governance" ;
    ontos:uiDisplayOrder 13 ;
    ontos:uiPersonaVisibility "admin,steward,producer,consumer" .

# --- Delivery channel assets ---

ontos:DeliveryChannel a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Delivery Channel"@en ;
    rdfs:comment "Mechanism through which data products expose data to consumers (dashboard, API, report, file, stream)"@en ;
    skos:example "Customer 360 API, CLV Dashboard, Daily Revenue Report, Partner Data Feed" ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Send" ;
    ontos:uiCategory "integration" ;
    ontos:uiDisplayOrder 3 ;
    ontos:uiPersonaVisibility "admin,steward,producer,consumer" .

# --- System assets ---

ontos:System a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "System"@en ;
    rdfs:comment "External system, platform, or service that contains or produces data assets"@en ;
    skos:example "Databricks Lakehouse, Salesforce CRM, Power BI Service" ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Server" ;
    ontos:uiCategory "system" ;
    ontos:uiDisplayOrder 2 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .

ontos:Catalog a rdfs:Class ;
    rdfs:subClassOf ontos:Asset ;
    rdfs:label "Catalog"@en ;
    rdfs:comment "Platform-level catalog (UC catalog, BQ project, Snowflake database) that groups schemas"@en ;
    skos:example "main, hive_metastore, my-gcp-project" ;
    skos:definition "Structural container between System and Schema in the platform hierarchy" ;
    ontos:modelTier "asset" ;
    ontos:uiIcon "Library" ;
    ontos:uiCategory "data" ;
    ontos:uiDisplayOrder 1 ;
    ontos:uiPersonaVisibility "admin,steward,producer" .


# ############################################################################
#
#   SECTION 5 — GOVERNANCE / SEMANTIC CLASSES (existing, retained)
#
# ############################################################################

ontos:BusinessGlossary a rdfs:Class ;
    rdfs:subClassOf ontos:GovernanceArtifact ;
    rdfs:label "Business Glossary"@en ;
    rdfs:comment "Hierarchical collection of business terms with organizational scope"@en ;
    skos:definition "Supports inheritance from corporate -> LOB -> department -> team levels" ;
    ontos:modelTier "dedicated" .

ontos:GlossaryTerm a rdfs:Class ;
    rdfs:subClassOf ontos:GovernanceArtifact ;
    rdfs:label "Glossary Term"@en ;
    rdfs:comment "Business term definition with synonyms, examples, and tagged assets"@en ;
    skos:example "Customer, Revenue, Product Category" ;
    ontos:modelTier "dedicated" .

ontos:AssetReview a rdfs:Class ;
    rdfs:subClassOf ontos:GovernanceArtifact ;
    rdfs:label "Asset Review"@en ;
    rdfs:comment "Approval workflow for Databricks assets including review status and comments"@en ;
    ontos:modelTier "dedicated" .

ontos:SemanticLink a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Semantic Link"@en ;
    rdfs:comment "Association between application entities and ontology concepts via IRIs"@en ;
    skos:definition "Enables semantic enrichment and knowledge graph navigation" ;
    ontos:modelTier "dedicated" .

ontos:OntologyConcept a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Ontology Concept"@en ;
    rdfs:comment "RDF/RDFS concept from loaded taxonomies with hierarchical relationships"@en ;
    ontos:modelTier "dedicated" .

ontos:KnowledgeCollection a rdfs:Class ;
    rdfs:subClassOf ontos:Entity ;
    rdfs:label "Knowledge Collection"@en ;
    rdfs:comment "Generic container for glossaries, taxonomies, or ontologies with hierarchical organization"@en ;
    skos:definition "Supports custom and imported knowledge systems with optional editing capability" ;
    ontos:modelTier "dedicated" .


# ############################################################################
#
#   SECTION 6 — OBJECT PROPERTIES: CORE BUSINESS HIERARCHY
#
#   These define the primary DP > Dataset > Table > Column hierarchy
#   and the governance relationships around it.
#
# ############################################################################

# --- Data Product hierarchy ---

ontos:hasDataset a owl:ObjectProperty ;
    rdfs:label "has dataset"@en ;
    rdfs:comment "Links a data product to its constituent datasets"@en ;
    rdfs:domain ontos:DataProduct ;
    rdfs:range ontos:Dataset ;
    ontos:uiLabel "Contains Datasets"@en ;
    ontos:inverseLabel "Data Product"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:hasCatalog a owl:ObjectProperty ;
    rdfs:label "has catalog"@en ;
    rdfs:comment "Links a system to a catalog/project/database it contains"@en ;
    rdfs:domain ontos:System ;
    rdfs:range ontos:Catalog ;
    ontos:uiLabel "Contains Catalogs"@en ;
    ontos:inverseLabel "System"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:hasSchema a owl:ObjectProperty ;
    rdfs:label "has schema"@en ;
    rdfs:comment "Links a system or catalog to a schema/namespace it contains"@en ;
    rdfs:domain ontos:System , ontos:Catalog ;
    rdfs:range ontos:Schema ;
    ontos:uiLabel "Contains Schemas"@en ;
    ontos:inverseLabel "Catalog"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:hasTable a owl:ObjectProperty ;
    rdfs:label "has table"@en ;
    rdfs:comment "Links a dataset or schema to a table it contains"@en ;
    rdfs:domain ontos:Dataset , ontos:Schema ;
    rdfs:range ontos:Table ;
    ontos:uiLabel "Contains Tables"@en ;
    ontos:inverseLabel "Dataset"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:hasView a owl:ObjectProperty ;
    rdfs:label "has view"@en ;
    rdfs:comment "Links a dataset or schema to a view it contains"@en ;
    rdfs:domain ontos:Dataset , ontos:Schema ;
    rdfs:range ontos:View ;
    ontos:uiLabel "Contains Views"@en ;
    ontos:inverseLabel "Dataset"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:hasColumn a owl:ObjectProperty ;
    rdfs:label "has column"@en ;
    rdfs:comment "Links a table or view to its columns"@en ;
    rdfs:domain ontos:Table , ontos:View ;
    rdfs:range ontos:Column ;
    ontos:uiLabel "Has Columns"@en ;
    ontos:inverseLabel "Table"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

# --- Governance relationships ---

ontos:governedBy a owl:ObjectProperty ;
    rdfs:label "governed by"@en ;
    rdfs:comment "Links a dataset to the data contract that governs its schema, quality, and SLA"@en ;
    rdfs:domain ontos:Dataset ;
    rdfs:range ontos:DataContract ;
    ontos:uiLabel "Governed by Contract"@en ;
    ontos:inverseLabel "Governed Datasets"@en ;
    ontos:cardinality "0..1" ;
    ontos:uiDisplayContext "detail-page" .

ontos:implementsContract a owl:ObjectProperty ;
    rdfs:label "implements contract"@en ;
    rdfs:comment "Links a physical table to the data contract it implements (for direct contract-table mapping)"@en ;
    rdfs:domain ontos:Table , ontos:View ;
    rdfs:range ontos:DataContract ;
    ontos:uiLabel "Implements Contract"@en ;
    ontos:inverseLabel "Implementing Tables"@en ;
    ontos:cardinality "0..1" ;
    ontos:uiDisplayContext "detail-page" .

ontos:attachedPolicy a owl:ObjectProperty ;
    rdfs:label "attached policy"@en ;
    rdfs:comment "Links an entity to a policy that applies to it"@en ;
    rdfs:domain ontos:DataProduct , ontos:DataContract , ontos:DataDomain ,
               ontos:Dataset , ontos:Schema , ontos:Table , ontos:View ,
               ontos:Column , ontos:System , ontos:Dashboard , ontos:Notebook ,
               ontos:MLModel , ontos:APIEndpoint , ontos:Stream ;
    rdfs:range ontos:Policy ;
    ontos:uiLabel "Has Policy"@en ;
    ontos:inverseLabel "Applied To"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" .

ontos:hasTerm a owl:ObjectProperty ;
    rdfs:label "has term"@en ;
    rdfs:comment "Links an entity to a business term that describes it"@en ;
    rdfs:domain ontos:DataProduct , ontos:DataContract , ontos:Dataset ,
               ontos:Table , ontos:View , ontos:Column , ontos:LogicalEntity ,
               ontos:LogicalAttribute , ontos:BusinessTerm , ontos:Dashboard ,
               ontos:MLModel , ontos:APIEndpoint , ontos:Stream ;
    rdfs:range ontos:BusinessTerm ;
    ontos:uiLabel "Annotated with"@en ;
    ontos:inverseLabel "Used By"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "sidebar" .


# ############################################################################
#
#   SECTION 7 — OBJECT PROPERTIES: ORGANIZATIONAL RELATIONSHIPS
#
# ############################################################################

ontos:belongsToDomain a owl:ObjectProperty ;
    rdfs:label "belongs to domain"@en ;
    rdfs:comment "Associates an entity with its parent data domain"@en ;
    rdfs:domain ontos:DataProduct , ontos:DataContract , ontos:Dataset ,
               ontos:Table , ontos:View , ontos:BusinessTerm ,
               ontos:LogicalEntity ;
    rdfs:range ontos:DataDomain ;
    ontos:uiLabel "Belongs to Domain"@en ;
    ontos:inverseLabel "Contains"@en ;
    ontos:cardinality "0..1" ;
    ontos:uiDisplayContext "detail-page" .

ontos:hasParentDomain a owl:ObjectProperty ;
    rdfs:label "has parent domain"@en ;
    rdfs:comment "Defines hierarchical relationship between data domains"@en ;
    rdfs:domain ontos:DataDomain ;
    rdfs:range ontos:DataDomain ;
    ontos:uiLabel "Parent Domain"@en ;
    ontos:inverseLabel "Sub-Domains"@en ;
    ontos:cardinality "0..1" ;
    ontos:uiDisplayContext "detail-page" ;
    ontos:isHierarchical true .

ontos:containsProduct a owl:ObjectProperty ;
    rdfs:label "contains product"@en ;
    rdfs:comment "Associates a data domain with its contained data products"@en ;
    rdfs:domain ontos:DataDomain ;
    rdfs:range ontos:DataProduct ;
    ontos:uiLabel "Contains Products"@en ;
    ontos:inverseLabel "Domain"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:ownedByTeam a owl:ObjectProperty ;
    rdfs:label "owned by team"@en ;
    rdfs:comment "Associates an entity with its owning team"@en ;
    rdfs:domain ontos:DataProduct , ontos:DataContract , ontos:DataDomain ,
               ontos:Dataset , ontos:Schema , ontos:Table , ontos:View ,
               ontos:System , ontos:Dashboard , ontos:Notebook , ontos:MLModel ,
               ontos:APIEndpoint , ontos:Stream ;
    rdfs:range ontos:Team ;
    ontos:uiLabel "Owned by"@en ;
    ontos:inverseLabel "Owns"@en ;
    ontos:cardinality "0..1" ;
    ontos:uiDisplayContext "detail-page" .

ontos:inProject a owl:ObjectProperty ;
    rdfs:label "in project"@en ;
    rdfs:comment "Associates an entity with its project scope"@en ;
    rdfs:domain ontos:DataProduct , ontos:DataContract , ontos:Dataset ;
    rdfs:range ontos:Project ;
    ontos:uiLabel "In Project"@en ;
    ontos:inverseLabel "Contains"@en ;
    ontos:cardinality "0..1" ;
    ontos:uiDisplayContext "detail-page" .

ontos:assignedToTeam a owl:ObjectProperty ;
    rdfs:label "assigned to team"@en ;
    rdfs:comment "Associates a project with one or more assigned teams"@en ;
    rdfs:domain ontos:Project ;
    rdfs:range ontos:Team ;
    ontos:uiLabel "Assigned to"@en ;
    ontos:inverseLabel "Projects"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" .

ontos:memberOfTeam a owl:ObjectProperty ;
    rdfs:label "member of team"@en ;
    rdfs:comment "Associates a team member with their team"@en ;
    rdfs:domain ontos:TeamMember ;
    rdfs:range ontos:Team ;
    ontos:cardinality "1..1" .


# ############################################################################
#
#   SECTION 7b — OBJECT PROPERTIES: BUSINESS LINEAGE & LOGICAL MODEL
#
# ############################################################################

ontos:relatesTo a owl:ObjectProperty ;
    rdfs:label "relates to"@en ;
    rdfs:comment "Links a business term to logical entities or attributes that define it"@en ;
    rdfs:domain ontos:BusinessTerm ;
    rdfs:range ontos:LogicalEntity , ontos:LogicalAttribute ;
    ontos:uiLabel "Related Logical Model"@en ;
    ontos:inverseLabel "Business Terms"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" .

ontos:hasLogicalAttribute a owl:ObjectProperty ;
    rdfs:label "has logical attribute"@en ;
    rdfs:comment "Links a logical entity to its constituent attributes"@en ;
    rdfs:domain ontos:LogicalEntity ;
    rdfs:range ontos:LogicalAttribute ;
    ontos:uiLabel "Has Attributes"@en ;
    ontos:inverseLabel "Logical Entity"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:implementedBy a owl:ObjectProperty ;
    rdfs:label "implemented by"@en ;
    rdfs:comment "Links a logical attribute to the physical assets (columns, datasets) that implement it"@en ;
    rdfs:domain ontos:LogicalAttribute ;
    rdfs:range ontos:Dataset , ontos:Column ;
    ontos:uiLabel "Implemented By"@en ;
    ontos:inverseLabel "Implements"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" .

ontos:exposes a owl:ObjectProperty ;
    rdfs:label "exposes"@en ;
    rdfs:comment "Links a data product to the delivery channels through which it serves data"@en ;
    rdfs:domain ontos:DataProduct ;
    rdfs:range ontos:DeliveryChannel ;
    ontos:uiLabel "Exposes"@en ;
    ontos:inverseLabel "Exposed By"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:hasOutputPort a owl:ObjectProperty ;
    rdfs:label "has output port"@en ;
    rdfs:comment "Links a data product to its output ports (deliverables)"@en ;
    rdfs:domain ontos:DataProduct ;
    rdfs:range ontos:OutputPort ;
    ontos:uiLabel "Has Output Ports"@en ;
    ontos:inverseLabel "Data Product"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:portHasTable a owl:ObjectProperty ;
    rdfs:label "port has table"@en ;
    rdfs:comment "Links an output port to a table it delivers"@en ;
    rdfs:domain ontos:OutputPort ;
    rdfs:range ontos:Table ;
    ontos:uiLabel "Delivers"@en ;
    ontos:inverseLabel "Delivered By Port"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:portHasView a owl:ObjectProperty ;
    rdfs:label "port has view"@en ;
    rdfs:comment "Links an output port to a view it delivers"@en ;
    rdfs:domain ontos:OutputPort ;
    rdfs:range ontos:View ;
    ontos:uiLabel "Delivers"@en ;
    ontos:inverseLabel "Delivered By Port"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:portHasDataset a owl:ObjectProperty ;
    rdfs:label "port has dataset"@en ;
    rdfs:comment "Links an output port to a dataset it delivers"@en ;
    rdfs:domain ontos:OutputPort ;
    rdfs:range ontos:Dataset ;
    ontos:uiLabel "Delivers"@en ;
    ontos:inverseLabel "Delivered By Port"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:portHasEndpoint a owl:ObjectProperty ;
    rdfs:label "port has endpoint"@en ;
    rdfs:comment "Links an output port to an API endpoint it delivers"@en ;
    rdfs:domain ontos:OutputPort ;
    rdfs:range ontos:APIEndpoint ;
    ontos:uiLabel "Delivers"@en ;
    ontos:inverseLabel "Delivered By Port"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:portHasModel a owl:ObjectProperty ;
    rdfs:label "port has model"@en ;
    rdfs:comment "Links an output port to an ML model it delivers"@en ;
    rdfs:domain ontos:OutputPort ;
    rdfs:range ontos:MLModel ;
    ontos:uiLabel "Delivers"@en ;
    ontos:inverseLabel "Delivered By Port"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" ;
    ontos:isHierarchical true .

ontos:dependsOn a owl:ObjectProperty ;
    rdfs:label "depends on"@en ;
    rdfs:comment "Links a data product to upstream data products it depends on"@en ;
    rdfs:domain ontos:DataProduct ;
    rdfs:range ontos:DataProduct ;
    ontos:uiLabel "Depends On"@en ;
    ontos:inverseLabel "Depended On By"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" .

ontos:contractFor a owl:ObjectProperty ;
    rdfs:label "contract for"@en ;
    rdfs:comment "Links a data contract to the datasets or API endpoints it governs"@en ;
    rdfs:domain ontos:DataContract ;
    rdfs:range ontos:Dataset , ontos:APIEndpoint ;
    ontos:uiLabel "Contract For"@en ;
    ontos:inverseLabel "Governed By Contract"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" .

ontos:appliesTo a owl:ObjectProperty ;
    rdfs:label "applies to"@en ;
    rdfs:comment "Links a policy to the entities it governs"@en ;
    rdfs:domain ontos:Policy ;
    rdfs:range ontos:DataDomain , ontos:BusinessTerm , ontos:LogicalAttribute , ontos:DataProduct ;
    ontos:uiLabel "Applies To"@en ;
    ontos:inverseLabel "Governed By Policy"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" .


# ############################################################################
#
#   SECTION 8 — OBJECT PROPERTIES: CONSUMPTION & LINEAGE
#
# ############################################################################

ontos:consumesFrom a owl:ObjectProperty ;
    rdfs:label "consumes from"@en ;
    rdfs:comment "Indicates an asset reads or depends on another asset"@en ;
    rdfs:domain ontos:Dataset , ontos:Table , ontos:View , ontos:Dashboard ,
               ontos:Notebook , ontos:MLModel , ontos:APIEndpoint , ontos:Stream ;
    rdfs:range ontos:Asset ;
    ontos:uiLabel "Consumes From"@en ;
    ontos:inverseLabel "Consumed By"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" .

ontos:producesTo a owl:ObjectProperty ;
    rdfs:label "produces to"@en ;
    rdfs:comment "Indicates an asset writes to or feeds another asset"@en ;
    rdfs:domain ontos:Dataset , ontos:Table , ontos:View , ontos:Notebook ,
               ontos:MLModel , ontos:APIEndpoint , ontos:Stream ;
    rdfs:range ontos:Asset ;
    ontos:uiLabel "Produces To"@en ;
    ontos:inverseLabel "Produced By"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "tab" .

ontos:belongsToSystem a owl:ObjectProperty ;
    rdfs:label "belongs to system"@en ;
    rdfs:comment "Associates an asset with its host system or platform"@en ;
    rdfs:domain ontos:Schema , ontos:Dataset , ontos:Table , ontos:View ,
               ontos:Dashboard , ontos:Notebook , ontos:MLModel ,
               ontos:APIEndpoint , ontos:Stream ;
    rdfs:range ontos:System ;
    ontos:uiLabel "Belongs to System"@en ;
    ontos:inverseLabel "Contains"@en ;
    ontos:cardinality "0..1" ;
    ontos:uiDisplayContext "detail-page" ;
    ontos:isHierarchical true .

ontos:deployedOnSystem a owl:ObjectProperty ;
    rdfs:label "deployed on system"@en ;
    rdfs:comment "Links a data product to the system or platform where it is deployed"@en ;
    rdfs:domain ontos:DataProduct ;
    rdfs:range ontos:System ;
    ontos:uiLabel "Deployed On"@en ;
    ontos:inverseLabel "Hosts Product"@en ;
    ontos:cardinality "0..1" ;
    ontos:uiDisplayContext "detail-page" ;
    ontos:isHierarchical true .

ontos:replacedBy a owl:ObjectProperty ;
    rdfs:label "replaced by"@en ;
    rdfs:comment "Indicates a deprecated asset has been replaced by a newer one"@en ;
    rdfs:domain ontos:Schema , ontos:Dataset , ontos:Table , ontos:View ,
               ontos:Dashboard , ontos:Notebook , ontos:MLModel ,
               ontos:APIEndpoint , ontos:Stream ;
    rdfs:range ontos:Asset ;
    ontos:uiLabel "Replaced By"@en ;
    ontos:inverseLabel "Replaces"@en ;
    ontos:cardinality "0..1" ;
    ontos:uiDisplayContext "detail-page" .


# ############################################################################
#
#   SECTION 9 — OBJECT PROPERTIES: SEMANTIC & GOVERNANCE (existing, retained)
#
# ############################################################################

ontos:hasOwner a owl:ObjectProperty ;
    rdfs:label "has owner"@en ;
    rdfs:comment "Links an entity to an ownership record"@en ;
    rdfs:domain ontos:DataProduct , ontos:DataContract , ontos:DataDomain ,
               ontos:Dataset , ontos:Schema , ontos:Table , ontos:View ,
               ontos:System , ontos:Dashboard , ontos:Notebook , ontos:MLModel ,
               ontos:APIEndpoint , ontos:Stream , ontos:Policy ,
               ontos:BusinessTerm , ontos:LogicalEntity ;
    rdfs:range ontos:Ownership .

ontos:hasSemanticConcept a owl:ObjectProperty ;
    rdfs:label "has semantic concept"@en ;
    rdfs:comment "Links an entity to ontology concepts for semantic enrichment"@en ;
    rdfs:domain ontos:DataProduct , ontos:DataContract , ontos:Dataset ,
               ontos:Table , ontos:View , ontos:Column , ontos:LogicalEntity ,
               ontos:LogicalAttribute , ontos:BusinessTerm ;
    rdfs:range ontos:OntologyConcept ;
    ontos:uiLabel "Has Concepts"@en ;
    ontos:cardinality "0..*" ;
    ontos:uiDisplayContext "sidebar" .

ontos:linkedToIRI a owl:ObjectProperty ;
    rdfs:label "linked to IRI"@en ;
    rdfs:comment "Direct reference to external ontology concept IRI"@en ;
    rdfs:domain ontos:SemanticLink .

ontos:derivedFromGlossary a owl:ObjectProperty ;
    rdfs:label "derived from glossary"@en ;
    rdfs:comment "Links an ontology concept to its source glossary term"@en ;
    rdfs:domain ontos:OntologyConcept ;
    rdfs:range ontos:GlossaryTerm .

ontos:parentGlossary a owl:ObjectProperty ;
    rdfs:label "parent glossary"@en ;
    rdfs:comment "Defines hierarchical inheritance between business glossaries"@en ;
    rdfs:domain ontos:BusinessGlossary ;
    rdfs:range ontos:BusinessGlossary .

ontos:reviewedBy a owl:ObjectProperty ;
    rdfs:label "reviewed by"@en ;
    rdfs:comment "Associates an asset with its review process"@en ;
    rdfs:domain ontos:DataProduct , ontos:DataContract , ontos:Dataset ,
               ontos:Table , ontos:View ;
    rdfs:range ontos:AssetReview .

ontos:taggedWithConcept a owl:ObjectProperty ;
    rdfs:label "tagged with concept"@en ;
    rdfs:comment "Associates a glossary term with tagged Databricks assets"@en ;
    rdfs:domain ontos:GlossaryTerm .

ontos:semanticAssignment a owl:ObjectProperty ;
    rdfs:label "semantic assignment"@en ;
    rdfs:comment "Links any resource to a semantic concept from a loaded taxonomy or ontology"@en ;
    rdfs:range ontos:OntologyConcept .

ontos:conceptAssignment a owl:ObjectProperty ;
    rdfs:subPropertyOf ontos:semanticAssignment ;
    rdfs:label "concept assignment"@en ;
    rdfs:comment "Links a resource to an ontology class or concept"@en ;
    rdfs:range ontos:OntologyConcept .

ontos:propertyAssignment a owl:ObjectProperty ;
    rdfs:subPropertyOf ontos:semanticAssignment ;
    rdfs:label "property assignment"@en ;
    rdfs:comment "Links a resource to an ontology property"@en ;
    rdfs:range rdf:Property .


# ############################################################################
#
#   SECTION 10 — DATA PROPERTIES: COMMON (inherited by all entities)
#
# ############################################################################

# --- Identifiers ---

ontos:entityId a owl:DatatypeProperty ;
    rdfs:label "entity ID"@en ;
    rdfs:comment "Unique identifier for application entities"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string .

ontos:name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Human-readable name of the entity"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "text" ;
    ontos:uiFieldOrder 1 ;
    ontos:isRequired true ;
    ontos:uiFieldGroup "basic" .

ontos:displayTitle a owl:DatatypeProperty ;
    rdfs:label "display title"@en ;
    rdfs:comment "Optional display title for presentation purposes"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string .

ontos:description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "Human-readable description of the entity"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "textarea" ;
    ontos:uiFieldOrder 2 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" .

# --- Lifecycle ---

ontos:status a owl:DatatypeProperty ;
    rdfs:label "status"@en ;
    rdfs:comment "Current operational status"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 3 ;
    ontos:isRequired true ;
    ontos:uiFieldGroup "basic" ;
    ontos:uiSelectOptions "draft,sandbox,proposed,under_review,approved,active,deprecated,retired" .

ontos:version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:comment "Version identifier for versioned entities"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "text" ;
    ontos:uiFieldOrder 4 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" .

ontos:lifecycle a owl:DatatypeProperty ;
    rdfs:label "lifecycle"@en ;
    rdfs:comment "DEPRECATED — use ontos:status instead. Kept for backward compatibility."@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string ;
    owl:deprecated true ;
    skos:example "draft, active, deprecated, retired" .

# --- Descriptive ---

ontos:purpose a owl:DatatypeProperty ;
    rdfs:label "purpose"@en ;
    rdfs:comment "Intended purpose or business objective"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "textarea" ;
    ontos:uiFieldOrder 5 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" .

ontos:usage a owl:DatatypeProperty ;
    rdfs:label "usage"@en ;
    rdfs:comment "Intended usage patterns and guidelines"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string .

ontos:limitations a owl:DatatypeProperty ;
    rdfs:label "limitations"@en ;
    rdfs:comment "Known limitations or constraints"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string .

# --- Organizational scope ---

ontos:organizationalScope a owl:DatatypeProperty ;
    rdfs:label "organizational scope"@en ;
    rdfs:comment "Organizational level of applicability"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string ;
    skos:example "company, lob, department, team" .

ontos:organizationalUnit a owl:DatatypeProperty ;
    rdfs:label "organizational unit"@en ;
    rdfs:comment "Specific organizational unit identifier"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string .

# --- Ownership ---

ontos:owner a owl:DatatypeProperty ;
    rdfs:label "owner"@en ;
    rdfs:comment "Primary owner or responsible party"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string .

ontos:createdBy a owl:DatatypeProperty ;
    rdfs:label "created by"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string .

ontos:updatedBy a owl:DatatypeProperty ;
    rdfs:label "updated by"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string .

# --- Temporal ---

ontos:createdAt a owl:DatatypeProperty ;
    rdfs:label "created at"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:dateTime .

ontos:updatedAt a owl:DatatypeProperty ;
    rdfs:label "updated at"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:dateTime .

ontos:publishedAt a owl:DatatypeProperty ;
    rdfs:label "published at"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:dateTime .

ontos:publishedBy a owl:DatatypeProperty ;
    rdfs:label "published by"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:anyURI .

ontos:certifiedAt a owl:DatatypeProperty ;
    rdfs:label "certified at"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:dateTime .

ontos:certifiedBy a owl:DatatypeProperty ;
    rdfs:label "certified by"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:anyURI .

ontos:certificationExpiresAt a owl:DatatypeProperty ;
    rdfs:label "certification expires at"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:dateTime .

ontos:certificationLevel a owl:DatatypeProperty ;
    rdfs:label "certification level"@en ;
    rdfs:comment "Ordinal of the assigned certification level (references certification_levels table)"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:integer .

ontos:inheritedCertificationLevel a owl:DatatypeProperty ;
    rdfs:label "inherited certification level"@en ;
    rdfs:comment "Certification level inherited via entity relationships (BFS propagation)"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:integer .

ontos:certificationNotes a owl:DatatypeProperty ;
    rdfs:label "certification notes"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string .

ontos:publicationScope a owl:DatatypeProperty ;
    rdfs:label "publication scope"@en ;
    rdfs:comment "Visibility scope: none, domain, organization, external"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiSelectOptions "none,domain,organization,external" .


# ############################################################################
#
#   SECTION 11 — DATA PROPERTIES: ASSET-SPECIFIC FIELDS
#
#   These are the type-specific properties that the OntologySchemaService
#   extracts to build JSON Schemas for each asset type's form.
#
# ############################################################################

# --- Dataset-specific ---

ontos:datasetRole a owl:DatatypeProperty ;
    rdfs:label "dataset role"@en ;
    rdfs:comment "The business role of this dataset within its data product"@en ;
    rdfs:domain ontos:Dataset ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" ;
    ontos:uiSelectOptions "primary,supporting,reference,staging" .

# --- Table / View ---

ontos:physicalPath a owl:DatatypeProperty ;
    rdfs:label "physical path"@en ;
    rdfs:comment "Fully qualified path in the target system (e.g. catalog.schema.table)"@en ;
    rdfs:domain ontos:Table , ontos:View ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "text" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired true ;
    ontos:uiFieldGroup "technical" .

ontos:platform a owl:DatatypeProperty ;
    rdfs:label "platform"@en ;
    rdfs:comment "Data platform hosting this table or view"@en ;
    rdfs:domain ontos:Table , ontos:View ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" ;
    ontos:uiSelectOptions "databricks,snowflake,bigquery,redshift,postgres,s3,azure_storage,gcs" .

ontos:environment a owl:DatatypeProperty ;
    rdfs:label "environment"@en ;
    rdfs:comment "Deployment environment"@en ;
    rdfs:domain ontos:Table , ontos:View ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 12 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" ;
    ontos:uiSelectOptions "dev,qa,staging,prod" .

ontos:tableRole a owl:DatatypeProperty ;
    rdfs:label "table role"@en ;
    rdfs:comment "Role of this table within its dataset"@en ;
    rdfs:domain ontos:Table , ontos:View ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 13 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" ;
    ontos:uiSelectOptions "main,dimension,lookup,reference,staging" .

# --- Column ---

ontos:columnDataType a owl:DatatypeProperty ;
    rdfs:label "data type"@en ;
    rdfs:comment "Data type of the column (e.g. STRING, INT, TIMESTAMP)"@en ;
    rdfs:domain ontos:Column ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "text" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" .

ontos:isNullable a owl:DatatypeProperty ;
    rdfs:label "is nullable"@en ;
    rdfs:comment "Whether the column allows NULL values"@en ;
    rdfs:domain ontos:Column ;
    rdfs:range xsd:boolean ;
    ontos:uiFieldType "boolean" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" .

ontos:isPrimaryKey a owl:DatatypeProperty ;
    rdfs:label "is primary key"@en ;
    rdfs:domain ontos:Column ;
    rdfs:range xsd:boolean ;
    ontos:uiFieldType "boolean" ;
    ontos:uiFieldOrder 12 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" .

ontos:classification a owl:DatatypeProperty ;
    rdfs:label "classification"@en ;
    rdfs:comment "Data classification level (e.g. public, internal, confidential, restricted)"@en ;
    rdfs:domain ontos:Column ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 13 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "governance" ;
    ontos:uiSelectOptions "public,internal,confidential,restricted" .

# --- Policy ---

ontos:policyType a owl:DatatypeProperty ;
    rdfs:label "policy type"@en ;
    rdfs:comment "Category of governance policy"@en ;
    rdfs:domain ontos:Policy ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired true ;
    ontos:uiFieldGroup "basic" ;
    ontos:uiSelectOptions "access_privacy,data_quality,retention_lifecycle,usage_purpose,custom" .

ontos:enforcementLevel a owl:DatatypeProperty ;
    rdfs:label "enforcement level"@en ;
    rdfs:comment "How strictly this policy is enforced"@en ;
    rdfs:domain ontos:Policy ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired true ;
    ontos:uiFieldGroup "basic" ;
    ontos:uiSelectOptions "advisory,mandatory,automated" .

ontos:policyContent a owl:DatatypeProperty ;
    rdfs:label "policy content"@en ;
    rdfs:comment "The actual policy text or rules body"@en ;
    rdfs:domain ontos:Policy ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "textarea" ;
    ontos:uiFieldOrder 12 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" .

# --- BusinessTerm ---

ontos:termDefinition a owl:DatatypeProperty ;
    rdfs:label "definition"@en ;
    rdfs:comment "Formal business definition of the term"@en ;
    rdfs:domain ontos:BusinessTerm ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "textarea" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired true ;
    ontos:uiFieldGroup "basic" .

ontos:synonyms a owl:DatatypeProperty ;
    rdfs:label "synonyms"@en ;
    rdfs:comment "Alternative names or abbreviations for this term"@en ;
    rdfs:domain ontos:BusinessTerm ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "text" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" .

ontos:examples a owl:DatatypeProperty ;
    rdfs:label "examples"@en ;
    rdfs:comment "Usage examples for this term"@en ;
    rdfs:domain ontos:BusinessTerm ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "textarea" ;
    ontos:uiFieldOrder 12 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" .

# --- Dashboard ---

ontos:dashboardUrl a owl:DatatypeProperty ;
    rdfs:label "dashboard URL"@en ;
    rdfs:comment "URL to the dashboard in its BI platform"@en ;
    rdfs:domain ontos:Dashboard ;
    rdfs:range xsd:anyURI ;
    ontos:uiFieldType "url" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" .

ontos:dashboardPlatform a owl:DatatypeProperty ;
    rdfs:label "platform"@en ;
    rdfs:comment "BI platform hosting the dashboard"@en ;
    rdfs:domain ontos:Dashboard ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" ;
    ontos:uiSelectOptions "databricks,powerbi,tableau,looker,other" .

# --- APIEndpoint ---

ontos:endpointUrl a owl:DatatypeProperty ;
    rdfs:label "endpoint URL"@en ;
    rdfs:comment "URL pattern for the API endpoint"@en ;
    rdfs:domain ontos:APIEndpoint ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "text" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired true ;
    ontos:uiFieldGroup "technical" .

ontos:httpMethod a owl:DatatypeProperty ;
    rdfs:label "HTTP method"@en ;
    rdfs:domain ontos:APIEndpoint ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" ;
    ontos:uiSelectOptions "GET,POST,PUT,PATCH,DELETE" .

# --- Notebook ---

ontos:notebookPath a owl:DatatypeProperty ;
    rdfs:label "notebook path"@en ;
    rdfs:comment "Workspace path to the notebook"@en ;
    rdfs:domain ontos:Notebook ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "text" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" .

ontos:notebookLanguage a owl:DatatypeProperty ;
    rdfs:label "language"@en ;
    rdfs:domain ontos:Notebook ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" ;
    ontos:uiSelectOptions "python,sql,scala,r" .

# --- MLModel ---

ontos:modelRegistryName a owl:DatatypeProperty ;
    rdfs:label "registry name"@en ;
    rdfs:comment "Name of the model in the model registry"@en ;
    rdfs:domain ontos:MLModel ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "text" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" .

ontos:modelFramework a owl:DatatypeProperty ;
    rdfs:label "framework"@en ;
    rdfs:comment "ML framework used (e.g. sklearn, pytorch, spark)"@en ;
    rdfs:domain ontos:MLModel ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "text" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" .

# --- Stream ---

ontos:streamType a owl:DatatypeProperty ;
    rdfs:label "stream type"@en ;
    rdfs:comment "Type of streaming technology"@en ;
    rdfs:domain ontos:Stream ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" ;
    ontos:uiSelectOptions "kafka,kinesis,event_hub,pubsub,delta_live_tables" .

ontos:topicName a owl:DatatypeProperty ;
    rdfs:label "topic name"@en ;
    rdfs:comment "Topic or stream name"@en ;
    rdfs:domain ontos:Stream ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "text" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" .

# --- LogicalEntity ---

ontos:entityDomain a owl:DatatypeProperty ;
    rdfs:label "entity domain"@en ;
    rdfs:comment "The business domain this logical entity belongs to (e.g. Customer, Sales, Finance)"@en ;
    rdfs:domain ontos:LogicalEntity ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "text" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" .

ontos:entitySupertype a owl:DatatypeProperty ;
    rdfs:label "entity supertype"@en ;
    rdfs:comment "Parent entity in the conceptual model hierarchy (e.g. Party for Customer/Supplier)"@en ;
    rdfs:domain ontos:LogicalEntity ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "text" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" .

# --- LogicalAttribute ---

ontos:attributeDataType a owl:DatatypeProperty ;
    rdfs:label "logical data type"@en ;
    rdfs:comment "Logical data type of the attribute (e.g. String, Integer, Date, Boolean)"@en ;
    rdfs:domain ontos:LogicalAttribute ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" ;
    ontos:uiSelectOptions "String,Integer,Decimal,Boolean,Date,DateTime,Binary,Array,Map" .

ontos:isIdentifier a owl:DatatypeProperty ;
    rdfs:label "is identifier"@en ;
    rdfs:comment "Whether this attribute serves as a business identifier for the entity"@en ;
    rdfs:domain ontos:LogicalAttribute ;
    rdfs:range xsd:boolean ;
    ontos:uiFieldType "boolean" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" .

ontos:sensitivityLevel a owl:DatatypeProperty ;
    rdfs:label "sensitivity level"@en ;
    rdfs:comment "Data sensitivity classification for this attribute"@en ;
    rdfs:domain ontos:LogicalAttribute ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 12 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "governance" ;
    ontos:uiSelectOptions "public,internal,confidential,restricted,pii" .

# --- DeliveryChannel ---

ontos:channelType a owl:DatatypeProperty ;
    rdfs:label "channel type"@en ;
    rdfs:comment "Type of delivery mechanism"@en ;
    rdfs:domain ontos:DeliveryChannel ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired true ;
    ontos:uiFieldGroup "basic" ;
    ontos:uiSelectOptions "dashboard,report,api,file_export,stream,data_share,embedded_analytics" .

ontos:channelUrl a owl:DatatypeProperty ;
    rdfs:label "channel URL"@en ;
    rdfs:comment "Access URL for the delivery channel"@en ;
    rdfs:domain ontos:DeliveryChannel ;
    rdfs:range xsd:anyURI ;
    ontos:uiFieldType "url" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" .

ontos:channelFormat a owl:DatatypeProperty ;
    rdfs:label "output format"@en ;
    rdfs:comment "Data format delivered by the channel"@en ;
    rdfs:domain ontos:DeliveryChannel ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 12 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" ;
    ontos:uiSelectOptions "json,csv,parquet,delta,avro,html,pdf,excel" .

ontos:refreshFrequency a owl:DatatypeProperty ;
    rdfs:label "refresh frequency"@en ;
    rdfs:comment "How often the delivery channel is updated"@en ;
    rdfs:domain ontos:DeliveryChannel ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 13 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" ;
    ontos:uiSelectOptions "real_time,hourly,daily,weekly,monthly,on_demand" .

# --- System ---

ontos:systemType a owl:DatatypeProperty ;
    rdfs:label "system type"@en ;
    rdfs:comment "Category of the external system"@en ;
    rdfs:domain ontos:System ;
    rdfs:range xsd:string ;
    ontos:uiFieldType "select" ;
    ontos:uiFieldOrder 10 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "basic" ;
    ontos:uiSelectOptions "data_warehouse,data_lake,crm,erp,bi_platform,messaging,custom" .

ontos:systemUrl a owl:DatatypeProperty ;
    rdfs:label "system URL"@en ;
    rdfs:comment "Base URL or connection endpoint for the system"@en ;
    rdfs:domain ontos:System ;
    rdfs:range xsd:anyURI ;
    ontos:uiFieldType "url" ;
    ontos:uiFieldOrder 11 ;
    ontos:isRequired false ;
    ontos:uiFieldGroup "technical" .


# ############################################################################
#
#   SECTION 12 — DATA PROPERTIES: TEAM, MEMBERSHIP, SEMANTIC LINK (existing)
#
# ############################################################################

ontos:memberType a owl:DatatypeProperty ;
    rdfs:label "member type"@en ;
    rdfs:comment "Type of team member (user or group)"@en ;
    rdfs:domain ontos:TeamMember ;
    rdfs:range xsd:string ;
    skos:example "user, group" .

ontos:memberIdentifier a owl:DatatypeProperty ;
    rdfs:label "member identifier"@en ;
    rdfs:comment "Email for users, name for groups"@en ;
    rdfs:domain ontos:TeamMember ;
    rdfs:range xsd:string .

ontos:roleOverride a owl:DatatypeProperty ;
    rdfs:label "role override"@en ;
    rdfs:comment "Optional application role override for team member"@en ;
    rdfs:domain ontos:TeamMember ;
    rdfs:range xsd:string .

ontos:physicalName a owl:DatatypeProperty ;
    rdfs:label "physical name"@en ;
    rdfs:comment "Physical implementation name (e.g., table name, column name)"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string .

# --- Semantic link data properties ---

ontos:conceptIRI a owl:DatatypeProperty ;
    rdfs:label "concept IRI"@en ;
    rdfs:domain ontos:SemanticLink ;
    rdfs:range xsd:anyURI .

ontos:conceptLabel a owl:DatatypeProperty ;
    rdfs:label "concept label"@en ;
    rdfs:domain ontos:SemanticLink ;
    rdfs:range xsd:string .

ontos:linkingContext a owl:DatatypeProperty ;
    rdfs:label "linking context"@en ;
    rdfs:domain ontos:SemanticLink ;
    rdfs:range xsd:string .

# --- Ownership data properties ---

ontos:ownershipUser a owl:DatatypeProperty ;
    rdfs:label "ownership user"@en ;
    rdfs:domain ontos:Ownership ;
    rdfs:range xsd:anyURI ;
    skos:example "urn:user:alice@company.com" .

ontos:ownershipRole a owl:DatatypeProperty ;
    rdfs:label "ownership role"@en ;
    rdfs:domain ontos:Ownership ;
    rdfs:range xsd:string ;
    skos:example "business_owner, data_steward, technical_owner, sme, contributor" .

ontos:ownershipAssignedAt a owl:DatatypeProperty ;
    rdfs:label "ownership assigned at"@en ;
    rdfs:domain ontos:Ownership ;
    rdfs:range xsd:dateTime .

ontos:ownershipAssignedBy a owl:DatatypeProperty ;
    rdfs:label "ownership assigned by"@en ;
    rdfs:domain ontos:Ownership ;
    rdfs:range xsd:anyURI .

# --- Knowledge collection data properties ---

ontos:collectionType a owl:DatatypeProperty ;
    rdfs:label "collection type"@en ;
    rdfs:domain ontos:KnowledgeCollection ;
    rdfs:range xsd:string ;
    skos:example "glossary, taxonomy, ontology" .

ontos:scopeLevel a owl:DatatypeProperty ;
    rdfs:label "scope level"@en ;
    rdfs:domain ontos:KnowledgeCollection ;
    rdfs:range xsd:string ;
    skos:example "enterprise, domain, department, team, project, external" .

ontos:parentCollection a owl:ObjectProperty ;
    rdfs:label "parent collection"@en ;
    rdfs:domain ontos:KnowledgeCollection ;
    rdfs:range ontos:KnowledgeCollection .

ontos:isEditable a owl:DatatypeProperty ;
    rdfs:label "is editable"@en ;
    rdfs:domain ontos:KnowledgeCollection ;
    rdfs:range xsd:boolean .

ontos:sourceType a owl:DatatypeProperty ;
    rdfs:label "source type"@en ;
    rdfs:domain ontos:KnowledgeCollection ;
    rdfs:range xsd:string ;
    skos:example "custom, imported" .

ontos:sourceUrl a owl:DatatypeProperty ;
    rdfs:label "source URL"@en ;
    rdfs:domain ontos:KnowledgeCollection ;
    rdfs:range xsd:anyURI .

# --- Review / Provenance (existing) ---

ontos:reviewRequestId a owl:DatatypeProperty ;
    rdfs:label "review request ID"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string .

ontos:sourceConceptIri a owl:DatatypeProperty ;
    rdfs:label "source concept IRI"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:anyURI .

ontos:sourceCollectionIri a owl:DatatypeProperty ;
    rdfs:label "source collection IRI"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:anyURI .

ontos:promotionType a owl:DatatypeProperty ;
    rdfs:label "promotion type"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:string ;
    skos:example "promoted, demoted, migrated" .

ontos:promotedAt a owl:DatatypeProperty ;
    rdfs:label "promoted at"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:dateTime .

ontos:promotedBy a owl:DatatypeProperty ;
    rdfs:label "promoted by"@en ;
    rdfs:domain ontos:Entity ;
    rdfs:range xsd:anyURI .


# ############################################################################
#
#   SECTION 13 — USAGE EXAMPLES
#
# ############################################################################

# Full hierarchy example:
#
# ontos:customer-domain a ontos:DataDomain ;
#     ontos:name "Customer Domain" ;
#     ontos:description "Domain for customer-related data assets" ;
#     ontos:status "active" .
#
# ontos:customer-360-product a ontos:DataProduct ;
#     ontos:name "Customer 360 Product" ;
#     ontos:description "Comprehensive customer view" ;
#     ontos:status "active" ;
#     ontos:belongsToDomain ontos:customer-domain .
#
# ontos:customer-master-dataset a ontos:Dataset ;
#     ontos:name "Customer Master Dataset" ;
#     ontos:description "Core customer entity data" ;
#     ontos:status "active" ;
#     ontos:datasetRole "primary" .
#
# ontos:customer-360-product ontos:hasDataset ontos:customer-master-dataset .
# ontos:customer-master-dataset ontos:governedBy ontos:customer-data-contract .
#
# ontos:customer-table a ontos:Table ;
#     ontos:name "customers" ;
#     ontos:physicalPath "main.customer_data.customers" ;
#     ontos:platform "databricks" ;
#     ontos:environment "prod" ;
#     ontos:tableRole "main" .
#
# ontos:customer-master-dataset ontos:hasTable ontos:customer-table .
#
# ontos:customer-id-col a ontos:Column ;
#     ontos:name "customer_id" ;
#     ontos:columnDataType "STRING" ;
#     ontos:isPrimaryKey true ;
#     ontos:isNullable false ;
#     ontos:classification "internal" .
#
# ontos:customer-table ontos:hasColumn ontos:customer-id-col .
